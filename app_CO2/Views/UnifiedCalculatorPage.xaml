<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:app_CO2.ViewModels"
             xmlns:controls="clr-namespace:app_CO2.Views.Controls"
             xmlns:converters="clr-namespace:app_CO2.Converters"
             x:Class="app_CO2.Views.UnifiedCalculatorPage"
             x:DataType="vm:UnifiedCalculatorViewModel"
             Title="Calculadoras">

    <ContentPage.Resources>
        <converters:EnumToStringConverter x:Key="EnumToString" />
    </ContentPage.Resources>

    <Grid ColumnDefinitions="7*,3*" ColumnSpacing="16" Padding="20">

        <ScrollView Grid.Column="0">
            <VerticalStackLayout Spacing="8">

                <Label Text="Calculadoras de Emissão CO₂" Style="{StaticResource Title2}" />
                <Label Text="Digite os valores e o resultado será calculado automaticamente." Style="{StaticResource Caption1}" Opacity="0.7" Margin="0,0,0,2" />

                <!-- All cards share: 100px label | * picker | * input1 | * input2 | 2* results -->
                <!-- Cards with fewer inputs leave columns empty -->

                <!-- Concreto -->
                <Border Style="{StaticResource CardStyle}" Padding="12"
                        BindingContext="{Binding Concrete}" x:DataType="vm:ConcreteCalculatorViewModel">
                    <Grid ColumnDefinitions="100,*,*,*,2*" ColumnSpacing="12" RowSpacing="0">
                        <Label Text="Concreto" Style="{StaticResource Subtitle1}" VerticalOptions="Center" TextColor="{StaticResource Primary}" />
                        <VerticalStackLayout Grid.Column="1" Spacing="2">
                            <Label Text="Classe" Style="{StaticResource Caption2}" Opacity="0.6" />
                            <Picker ItemsSource="{Binding Grades}" SelectedItem="{Binding SelectedGrade}"
                                    ItemDisplayBinding="{Binding ., Converter={StaticResource EnumToString}}" />
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="2" Spacing="2">
                            <Label Text="Volume (m³)" Style="{StaticResource Caption2}" Opacity="0.6" />
                            <Entry Text="{Binding Volume}" Keyboard="Numeric" Placeholder="0" />
                        </VerticalStackLayout>
                        <!-- Column 3 empty -->
                        <controls:EmissionResultCard Grid.Column="4" BindingContext="{Binding .}" />
                    </Grid>
                </Border>

                <!-- Aço -->
                <Border Style="{StaticResource CardStyle}" Padding="12"
                        BindingContext="{Binding Steel}" x:DataType="vm:SteelCalculatorViewModel">
                    <Grid ColumnDefinitions="100,*,*,*,2*" ColumnSpacing="12" RowSpacing="0">
                        <Label Text="Aço" Style="{StaticResource Subtitle1}" VerticalOptions="Center" TextColor="{StaticResource Primary}" />
                        <VerticalStackLayout Grid.Column="1" Spacing="2">
                            <Label Text="Tipo" Style="{StaticResource Caption2}" Opacity="0.6" />
                            <Picker ItemsSource="{Binding Grades}" SelectedItem="{Binding SelectedGrade}"
                                    ItemDisplayBinding="{Binding ., Converter={StaticResource EnumToString}}" />
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="2" Spacing="2">
                            <Label Text="Massa (kg)" Style="{StaticResource Caption2}" Opacity="0.6" />
                            <Entry Text="{Binding Mass}" Keyboard="Numeric" Placeholder="0" />
                        </VerticalStackLayout>
                        <!-- Column 3 empty -->
                        <controls:EmissionResultCard Grid.Column="4" BindingContext="{Binding .}" />
                    </Grid>
                </Border>

                <!-- Fôrmas -->
                <Border Style="{StaticResource CardStyle}" Padding="12"
                        BindingContext="{Binding Formwork}" x:DataType="vm:FormworkCalculatorViewModel">
                    <Grid ColumnDefinitions="100,*,*,*,2*" ColumnSpacing="12" RowSpacing="0">
                        <Label Text="Fôrmas" Style="{StaticResource Subtitle1}" VerticalOptions="Center" TextColor="{StaticResource Primary}" />
                        <VerticalStackLayout Grid.Column="1" Spacing="2">
                            <Label Text="Material" Style="{StaticResource Caption2}" Opacity="0.6" />
                            <Picker ItemsSource="{Binding Materials}" SelectedItem="{Binding SelectedMaterial}"
                                    ItemDisplayBinding="{Binding ., Converter={StaticResource EnumToString}}" />
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="2" Spacing="2">
                            <Label Text="Área (m²)" Style="{StaticResource Caption2}" Opacity="0.6" />
                            <Entry Text="{Binding Area}" Keyboard="Numeric" Placeholder="0" />
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="3" Spacing="2">
                            <Label Style="{StaticResource Caption2}" Opacity="0.6">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="Reusos: " />
                                        <Span Text="{Binding Reuses}" FontAttributes="Bold" />
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>
                            <Slider Minimum="1" Maximum="50" Value="{Binding Reuses}" VerticalOptions="Center" />
                        </VerticalStackLayout>
                        <controls:EmissionResultCard Grid.Column="4" BindingContext="{Binding .}" />
                    </Grid>
                </Border>

                <!-- Transporte -->
                <Border Style="{StaticResource CardStyle}" Padding="12"
                        BindingContext="{Binding Transport}" x:DataType="vm:TransportCalculatorViewModel">
                    <Grid ColumnDefinitions="100,*,*,*,2*" ColumnSpacing="12" RowSpacing="0">
                        <Label Text="Transporte" Style="{StaticResource Subtitle1}" VerticalOptions="Center" TextColor="{StaticResource Primary}" />
                        <VerticalStackLayout Grid.Column="1" Spacing="2">
                            <Label Text="Modo" Style="{StaticResource Caption2}" Opacity="0.6" />
                            <Picker ItemsSource="{Binding Modes}" SelectedItem="{Binding SelectedMode}"
                                    ItemDisplayBinding="{Binding ., Converter={StaticResource EnumToString}}" />
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="2" Spacing="2">
                            <Label Text="Massa (kg)" Style="{StaticResource Caption2}" Opacity="0.6" />
                            <Entry Text="{Binding Mass}" Keyboard="Numeric" Placeholder="0" />
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="3" Spacing="2">
                            <Label Text="Distância (km)" Style="{StaticResource Caption2}" Opacity="0.6" />
                            <Entry Text="{Binding Distance}" Keyboard="Numeric" Placeholder="0" />
                        </VerticalStackLayout>
                        <controls:EmissionResultCard Grid.Column="4" BindingContext="{Binding .}" />
                    </Grid>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Right: History Panel -->
        <controls:HistoryPanel Grid.Column="1" BindingContext="{Binding HistoryPanel}" />

    </Grid>
</ContentPage>
