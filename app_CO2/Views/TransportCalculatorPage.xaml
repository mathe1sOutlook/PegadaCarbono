<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:app_CO2.ViewModels"
             xmlns:controls="clr-namespace:app_CO2.Views.Controls"
             x:Class="app_CO2.Views.TransportCalculatorPage"
             x:DataType="vm:TransportCalculatorViewModel"
             xmlns:converters="clr-namespace:app_CO2.Converters"
             Title="Transporte">

    <ContentPage.Resources>
        <converters:EnumToStringConverter x:Key="EnumToString" />
    </ContentPage.Resources>

    <Grid ColumnDefinitions="7*,3*" ColumnSpacing="16" Padding="20">

        <ScrollView Grid.Column="0">
            <VerticalStackLayout Spacing="16">

                <Label Text="Calculadora de Transporte" Style="{StaticResource Title1}" />
                <Label Text="Calcula a emissão de CO₂ do transporte com base no modo, massa e distância." Style="{StaticResource Body}" Opacity="0.7" />

                <Border Style="{StaticResource CardStyle}" Padding="20">
                    <VerticalStackLayout Spacing="16">
                        <Label Text="Modo de Transporte" Style="{StaticResource Subtitle2}" />
                        <Picker ItemsSource="{Binding Modes}" SelectedItem="{Binding SelectedMode}" Title="Selecione o modo"
                                ItemDisplayBinding="{Binding ., Converter={StaticResource EnumToString}}" />

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="Massa (kg)" Style="{StaticResource Subtitle2}" />
                                <Entry Text="{Binding Mass}" Keyboard="Numeric" Placeholder="Ex: 10000" />
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1" Spacing="4">
                                <Label Text="Distância (km)" Style="{StaticResource Subtitle2}" />
                                <Entry Text="{Binding Distance}" Keyboard="Numeric" Placeholder="Ex: 20" />
                            </VerticalStackLayout>
                        </Grid>

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                            <Button Text="Calcular" Command="{Binding CalculateCommand}" Style="{StaticResource PrimaryAction}" />
                            <Button Grid.Column="1" Text="Limpar" Command="{Binding ClearCommand}"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                                    TextColor="{AppThemeBinding Light={StaticResource DarkOnLightBackground}, Dark={StaticResource LightOnDarkBackground}}" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <controls:EmissionResultCard BindingContext="{Binding .}" />

            </VerticalStackLayout>
        </ScrollView>

        <controls:HistoryPanel Grid.Column="1" BindingContext="{Binding HistoryPanel}" />

    </Grid>
</ContentPage>
