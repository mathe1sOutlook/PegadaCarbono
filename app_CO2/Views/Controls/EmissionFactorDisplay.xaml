<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="app_CO2.Views.Controls.EmissionFactorDisplay">

    <Border StrokeShape="RoundRectangle 8" Padding="12,8" StrokeThickness="1"
            Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
            BackgroundColor="Transparent">
        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
            <VerticalStackLayout Spacing="2">
                <Label x:Name="FactorNameLabel" Style="{StaticResource Caption1}" FontAttributes="Bold" />
                <Label Style="{StaticResource Caption2}" Opacity="0.6">
                    <Label.FormattedText>
                        <FormattedString>
                            <Span x:Name="MinSpan" />
                            <Span Text=" – " />
                            <Span x:Name="MaxSpan" />
                            <Span Text=" " />
                            <Span x:Name="UnitSpan" />
                        </FormattedString>
                    </Label.FormattedText>
                </Label>
            </VerticalStackLayout>
            <Label x:Name="SourceLabel" Grid.Column="1" Style="{StaticResource Caption2}" Opacity="0.4" VerticalOptions="Center" />
        </Grid>
    </Border>
</ContentView>
