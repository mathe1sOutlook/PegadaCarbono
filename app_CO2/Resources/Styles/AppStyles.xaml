<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:f="clr-namespace:Fonts"
    xmlns:sf="clr-namespace:Syncfusion.Maui.Toolkit.TextInputLayout;assembly=Syncfusion.Maui.Toolkit"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Sizing -->
    <x:Double x:Key="sizeNone">0</x:Double>
    <x:Double x:Key="size80">8</x:Double>
    <x:Double x:Key="size100">10</x:Double>
    <x:Double x:Key="size120">12</x:Double>
    <x:Double x:Key="size160">16</x:Double>
    <x:Double x:Key="size200">20</x:Double>
    <x:Double x:Key="size240">24</x:Double>
    <x:Double x:Key="size320">32</x:Double>

    <x:Double x:Key="IconSize">32</x:Double>
    <x:Double x:Key="IconSizeSmall">18</x:Double>
    <Thickness x:Key="LayoutPadding">30</Thickness>
    <x:Double x:Key="LayoutSpacing">15</x:Double>

    <!-- Navigation Icons -->
    <FontImageSource x:Key="IconDashboard"
        Glyph="{x:Static f:FluentUI.diagram_24_regular}" FontFamily="{x:Static f:FluentUI.FontFamily}"
        Color="{AppThemeBinding Light={StaticResource DarkOnLightBackground}, Dark={StaticResource LightOnDarkBackground}}"
        Size="{StaticResource IconSize}" />

    <FontImageSource x:Key="IconConcrete"
        Glyph="{x:Static f:FluentUI.cube_20_regular}" FontFamily="{x:Static f:FluentUI.FontFamily}"
        Color="{AppThemeBinding Light={StaticResource DarkOnLightBackground}, Dark={StaticResource LightOnDarkBackground}}"
        Size="{StaticResource IconSize}" />

    <FontImageSource x:Key="IconSteel"
        Glyph="{x:Static f:FluentUI.ribbon_20_regular}" FontFamily="{x:Static f:FluentUI.FontFamily}"
        Color="{AppThemeBinding Light={StaticResource DarkOnLightBackground}, Dark={StaticResource LightOnDarkBackground}}"
        Size="{StaticResource IconSize}" />

    <FontImageSource x:Key="IconFormwork"
        Glyph="{x:Static f:FluentUI.document_table_20_regular}" FontFamily="{x:Static f:FluentUI.FontFamily}"
        Color="{AppThemeBinding Light={StaticResource DarkOnLightBackground}, Dark={StaticResource LightOnDarkBackground}}"
        Size="{StaticResource IconSize}" />

    <FontImageSource x:Key="IconTransport"
        Glyph="{x:Static f:FluentUI.vehicle_truck_20_regular}" FontFamily="{x:Static f:FluentUI.FontFamily}"
        Color="{AppThemeBinding Light={StaticResource DarkOnLightBackground}, Dark={StaticResource LightOnDarkBackground}}"
        Size="{StaticResource IconSize}" />

    <FontImageSource x:Key="IconBuilding"
        Glyph="{x:Static f:FluentUI.building_24_regular}" FontFamily="{x:Static f:FluentUI.FontFamily}"
        Color="{AppThemeBinding Light={StaticResource DarkOnLightBackground}, Dark={StaticResource LightOnDarkBackground}}"
        Size="{StaticResource IconSize}" />

    <FontImageSource x:Key="IconTables"
        Glyph="{x:Static f:FluentUI.table_calculator_20_regular}" FontFamily="{x:Static f:FluentUI.FontFamily}"
        Color="{AppThemeBinding Light={StaticResource DarkOnLightBackground}, Dark={StaticResource LightOnDarkBackground}}"
        Size="{StaticResource IconSize}" />

    <FontImageSource x:Key="IconAbout"
        Glyph="{x:Static f:FluentUI.earth_leaf_20_regular}" FontFamily="{x:Static f:FluentUI.FontFamily}"
        Color="{AppThemeBinding Light={StaticResource DarkOnLightBackground}, Dark={StaticResource LightOnDarkBackground}}"
        Size="{StaticResource IconSize}" />

    <FontImageSource x:Key="IconAdd"
        Glyph="{x:Static f:FluentUI.add_32_regular}" FontFamily="{x:Static f:FluentUI.FontFamily}"
        Color="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource LightOnDarkBackground}}"
        Size="{StaticResource IconSize}" />

    <FontImageSource x:Key="IconDelete"
        Glyph="{x:Static f:FluentUI.delete_32_regular}" FontFamily="{x:Static f:FluentUI.FontFamily}"
        Color="{AppThemeBinding Light={StaticResource DarkOnLightBackground}, Dark={StaticResource LightOnDarkBackground}}"
        Size="{StaticResource IconSize}" />

    <FontImageSource x:Key="IconHistory"
        Glyph="{x:Static f:FluentUI.history_24_regular}" FontFamily="{x:Static f:FluentUI.FontFamily}"
        Color="{AppThemeBinding Light={StaticResource DarkOnLightBackground}, Dark={StaticResource LightOnDarkBackground}}"
        Size="{StaticResource IconSize}" />

    <FontImageSource x:Key="IconLight"
        Glyph="{x:Static f:FluentUI.weather_sunny_28_regular}" FontFamily="{x:Static f:FluentUI.FontFamily}"
        Color="{AppThemeBinding Light={StaticResource DarkOnLightBackground}, Dark={StaticResource LightOnDarkBackground}}"
        Size="{StaticResource size240}" />

    <FontImageSource x:Key="IconDark"
        Glyph="{x:Static f:FluentUI.weather_moon_28_regular}" FontFamily="{x:Static f:FluentUI.FontFamily}"
        Color="{AppThemeBinding Light={StaticResource DarkOnLightBackground}, Dark={StaticResource LightOnDarkBackground}}"
        Size="{StaticResource size240}" />

    <!-- Typography (Fluent Design) -->
    <Style TargetType="Label">
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource DarkOnLightBackground}, Dark={StaticResource LightOnDarkBackground}}" />
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="FontSize" Value="17" />
        <Setter Property="LineHeight" Value="1.29" />
    </Style>

    <Style x:Key="Caption2" TargetType="Label">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="LineHeight" Value="1.33" />
    </Style>

    <Style x:Key="Caption1" TargetType="Label">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="LineHeight" Value="1.38" />
    </Style>

    <Style x:Key="Caption1Strong" TargetType="Label">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="LineHeight" Value="1.38" />
        <Setter Property="FontFamily" Value="SegoeSemibold" />
    </Style>

    <Style x:Key="Subtitle2" TargetType="Label">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="LineHeight" Value="1.29" />
        <Setter Property="FontFamily" Value="SegoeSemibold" />
    </Style>

    <Style x:Key="Subtitle1" TargetType="Label">
        <Setter Property="FontSize" Value="16" />
        <Setter Property="LineHeight" Value="1.25" />
        <Setter Property="FontFamily" Value="SegoeSemibold" />
    </Style>

    <Style x:Key="Body" TargetType="Label">
        <Setter Property="FontSize" Value="15" />
        <Setter Property="LineHeight" Value="1.33" />
    </Style>

    <Style x:Key="Body2" TargetType="Label">
        <Setter Property="FontSize" Value="15" />
        <Setter Property="LineHeight" Value="1.33" />
    </Style>

    <Style x:Key="Body1" TargetType="Label">
        <Setter Property="FontSize" Value="17" />
        <Setter Property="LineHeight" Value="1.29" />
    </Style>

    <Style x:Key="Body1Strong" TargetType="Label">
        <Setter Property="FontSize" Value="17" />
        <Setter Property="LineHeight" Value="1.29" />
        <Setter Property="FontFamily" Value="SegoeSemibold" />
    </Style>

    <Style x:Key="Title3" TargetType="Label">
        <Setter Property="FontSize" Value="20" />
        <Setter Property="LineHeight" Value="1.25" />
        <Setter Property="FontFamily" Value="SegoeSemibold" />
    </Style>

    <Style x:Key="Title2" TargetType="Label">
        <Setter Property="FontSize" Value="22" />
        <Setter Property="LineHeight" Value="1.27" />
        <Setter Property="FontFamily" Value="SegoeSemibold" />
    </Style>

    <Style x:Key="Title1" TargetType="Label">
        <Setter Property="FontSize" Value="28" />
        <Setter Property="LineHeight" Value="1.21" />
        <Setter Property="FontAttributes" Value="None" />
    </Style>

    <Style x:Key="LargeTitle" TargetType="Label">
        <Setter Property="FontSize" Value="34" />
        <Setter Property="LineHeight" Value="1.21" />
        <Setter Property="FontAttributes" Value="None" />
    </Style>

    <Style x:Key="Display" TargetType="Label">
        <Setter Property="FontSize" Value="60" />
        <Setter Property="LineHeight" Value="1.17" />
        <Setter Property="FontAttributes" Value="None" />
    </Style>

    <!-- Cards -->
    <Style TargetType="Border">
        <Setter Property="StrokeShape" Value="RoundRectangle 12"/>
        <Setter Property="Background" Value="{AppThemeBinding Light={StaticResource LightSecondaryBackground},Dark={StaticResource DarkSecondaryBackground}}"/>
        <Setter Property="Stroke" Value="{AppThemeBinding Light=#E0E0E0, Dark=#333333}" />
        <Setter Property="StrokeThickness" Value="0.5"/>
        <Setter Property="Padding" Value="20"/>
        <Setter Property="Shadow">
            <Setter.Value>
                <Shadow Brush="{AppThemeBinding Light=#33000000, Dark=#66000000}" Offset="0,2" Radius="8" Opacity="0.5" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="Border" x:Key="CardStyle">
        <Setter Property="StrokeShape" Value="RoundRectangle 12"/>
        <Setter Property="Background" Value="{AppThemeBinding Light={StaticResource LightSecondaryBackground},Dark={StaticResource DarkSecondaryBackground}}"/>
        <Setter Property="Stroke" Value="{AppThemeBinding Light=#E0E0E0, Dark=#333333}" />
        <Setter Property="StrokeThickness" Value="0.5"/>
        <Setter Property="Padding" Value="20"/>
        <Setter Property="Shadow">
            <Setter.Value>
                <Shadow Brush="{AppThemeBinding Light=#33000000, Dark=#66000000}" Offset="0,2" Radius="8" Opacity="0.5" />
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Monospace for numeric values -->
    <Style x:Key="NumericValue" TargetType="Label">
        <Setter Property="FontFamily" Value="Consolas" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource DarkOnLightBackground}, Dark={StaticResource LightOnDarkBackground}}" />
    </Style>

    <Style x:Key="NumericLarge" TargetType="Label">
        <Setter Property="FontFamily" Value="Consolas" />
        <Setter Property="FontSize" Value="34" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource DarkOnLightBackground}, Dark={StaticResource LightOnDarkBackground}}" />
    </Style>

    <!-- TextInputLayout -->
    <sf:LabelStyle x:Key="lightThemeLabelStyle" TextColor="{StaticResource DarkOnLightBackground}" FontSize="16"/>
    <sf:LabelStyle x:Key="darkThemeLabelStyle" TextColor="{StaticResource LightOnDarkBackground}" FontSize="16"/>
    <Style TargetType="sf:SfTextInputLayout">
        <Setter Property="ContainerType" Value="Outlined"/>
        <Setter Property="ContainerBackground" Value="Transparent"/>
        <Setter Property="Stroke" Value="{AppThemeBinding Light={StaticResource DarkOnLightBackground}, Dark={StaticResource LightOnDarkBackground}}"/>
        <Setter Property="HintLabelStyle" Value="{AppThemeBinding Light={StaticResource lightThemeLabelStyle}, Dark={StaticResource darkThemeLabelStyle}}"/>
    </Style>

    <!-- Button Styles -->
    <Style x:Key="PrimaryAction" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
        <Setter Property="TextColor" Value="White" />
        <Setter Property="FontFamily" Value="SegoeSemibold" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="16,10" />
    </Style>

    <Style x:Key="SecondaryAction" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource DarkOnLightBackground}, Dark={StaticResource LightOnDarkBackground}}" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="16,10" />
    </Style>

</ResourceDictionary>
